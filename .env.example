# ── Bloomberg Terminal Clone — Environment Variables ──
# All keys are SERVER-SIDE only (used inside /app/api routes). Never exposed to the browser.

# Finnhub — stock quotes, profiles, news, forex, crypto, earnings, IPO
# Get a free key: https://finnhub.io/register
FINNHUB_KEY=

# Alpha Vantage — OHLCV historical data, technical indicators, sector performance
# Get a free key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=

# NewsAPI — financial & company news
# Get a free key: https://newsapi.org/register
NEWS_API_KEY=

# FRED (St. Louis Fed) — GDP, CPI, unemployment, Fed funds, yields, M2
# Get a free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_KEY=

# CoinGecko — crypto prices (optional demo key for higher limits)
# Get a free demo key: https://www.coingecko.com/en/api
COINGECKO_KEY=

# Public app name (the only NEXT_PUBLIC_ var)
NEXT_PUBLIC_APP_NAME=Bloomberg Terminal
